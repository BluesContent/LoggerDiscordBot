# ===== Segredos e globais =====
# (Projetos, mensagens, agenda e config de intervalo/fuso ficam no Supabase —
#  editáveis pelo painel web. Aqui só entram segredos e credenciais.)

# Token do seu bot (Discord Developer Portal > sua aplicação > Bot > Reset Token)
DISCORD_TOKEN=cole_o_token_do_bot_aqui

# ===== Google Drive =====
# Uso LOCAL (no seu computador): caminho para o arquivo da Conta de Serviço
GOOGLE_CREDENTIALS_FILE=credentials/service_account.json

# Uso na VERCEL: cole aqui o CONTEÚDO INTEIRO do arquivo service_account.json
# (numa linha só). Na Vercel isso vira uma variável de ambiente; localmente
# pode deixar em branco (o GOOGLE_CREDENTIALS_FILE acima é usado no lugar).
GOOGLE_SERVICE_ACCOUNT_JSON=

# ===== Supabase (banco de dados na nuvem — guarda projetos e histórico) =====
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=cole_a_chave_service_role_aqui

# ===== Painel web =====
# Senha para acessar o painel (deixe em branco para não pedir senha — recomendado
# só localmente; na Vercel defina uma senha forte).
PANEL_PASSWORD=

# Chave aleatória para assinar a sessão de login do painel (qualquer texto longo).
FLASK_SECRET_KEY=troque_por_um_texto_aleatorio_longo

# ===== Endpoint de checagem automática (api/cron.py) =====
# Segredo que o GitHub Actions envia para provar que tem permissão de disparar
# a checagem. Gere um texto aleatório longo e use o MESMO valor no GitHub
# (Settings > Secrets and variables > Actions > CRON_SECRET).
CRON_SECRET=troque_por_um_texto_aleatorio_longo
