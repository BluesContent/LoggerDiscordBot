# ===== Segredos e globais =====
# (Projetos, mensagens, agenda e config de intervalo/fuso ficam em data/,
#  editáveis pelo painel web. Aqui só entram segredos e credenciais.)

# Token do seu bot (Discord Developer Portal > sua aplicação > Bot > Reset Token)
DISCORD_TOKEN=cole_o_token_do_bot_aqui

# ===== Google Drive =====
# Caminho para o arquivo da Conta de Serviço (baixado do Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials/service_account.json

# ===== Painel web =====
# Senha para acessar o painel (opcional — deixe em branco para não pedir senha).
PANEL_PASSWORD=

# Chave aleatória para assinar a sessão de login do painel (só necessária se
# PANEL_PASSWORD estiver definido). Qualquer texto longo serve.
FLASK_SECRET_KEY=troque_por_um_texto_aleatorio_longo

# ===== Uso futuro (nuvem) =====
# Não usado no modo local. Só relevante se um dia reativar o deploy na Vercel
# (api/cron.py) — pode deixar em branco por enquanto.
GOOGLE_SERVICE_ACCOUNT_JSON=
CRON_SECRET=
