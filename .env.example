# ===== Segredos e globais =====
# (As configuracoes de CADA projeto - pasta, canal, mensagem, indices, horario -
#  ficam no arquivo projects.json, nao aqui.)

# Token do seu bot (Discord Developer Portal > sua aplicacao > Bot > Reset Token)
DISCORD_TOKEN=cole_o_token_do_bot_aqui

# Caminho para o arquivo JSON da Conta de Servico do Google
GOOGLE_CREDENTIALS_FILE=credentials/service_account.json

# De quanto em quanto tempo o bot verifica o Drive (em segundos). 300 = 5 minutos.
POLL_INTERVAL_SECONDS=300

# Fuso horario usado para calcular a "data de hoje" e as janelas de horario
TIMEZONE=America/Sao_Paulo

# Formato do nome das pastas de data (20260714 = %Y%m%d)
DATE_FORMAT=%Y%m%d
